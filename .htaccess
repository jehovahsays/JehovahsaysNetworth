# MEV - Blackhole for Bad Bots & Root Protection

# 1. Disable Directory Browsing
Options -Indexes

# 2. Set the Gateway
<IfModule dir_module>
    DirectoryIndex index.html
</IfModule>

# 3. Protect the Wiki Interface
# This prevents direct access to wiki.html. 
# Users must pass through the index.html "Gatekeeper" first.
<Files "wiki.html">
    <IfModule authz_core_module>
        # Allow internal redirects but deny direct external requests
        RewriteEngine On
        RewriteCond %{HTTP_REFERER} !^https?://(localhost|127\.0\.0\.1) [NC]
        RewriteRule ^ - [F]
    </IfModule>
</Files>

# 4. MIME Type Integrity
# Ensures scripts and text files are served as plain text as defined in your map
AddType text/plain .ts .txt
AddType image/png .png

# 5. Security Headers
# Matches the CSP defined in your conscious interface
<IfModule mod_headers.c>
    Header set Content-Security-Policy "default-src 'self' data: blob:; script-src 'self' 'unsafe-inline'; object-src 'none'; style-src 'self' 'unsafe-inline';"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "no-referrer"
</IfModule>
